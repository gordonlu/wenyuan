{
  "$schema": "https://raw.githubusercontent.com/nicoulaj/tauri-config-schema/refs/heads/main/schema.json",
  "productName": "Wenyuan",
  "version": "0.1.1",
  "identifier": "com.wenyuan.desktop",
  "build": {
    "frontendDist": "../src",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "",
    "beforeBuildCommand": ""
  },
  "app": {
    "windows": [
      {
        "title": "文渊阁 Wenyuan",
        "width": 1400,
        "height": 860,
        "minWidth": 1100,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "url": "index.html"
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
