# WENYUAN_LLM_BASE_URL=
# WENYUAN_LLM_API_KEY=
# WENYUAN_LLM_MODEL=mock-model
# WENYUAN_LLM_TIMEOUT_SECS=120

# ── DeepSeek 直连 ──────────────────────────────────────
# WENYUAN_LLM_BASE_URL=https://api.deepseek.com/v1
# WENYUAN_LLM_API_KEY=sk-deepseek-xxxx
# WENYUAN_LLM_MODEL=deepseek-v4-flash
# 三席不同模型示例：
# WENYUAN_LLM_MODEL_MOUYUAN=deepseek-v4-flash   # 谋远席
# WENYUAN_LLM_MODEL_JINGSHI=deepseek-v4-pro     # 经世席
# WENYUAN_LLM_MODEL_CHIZHENG=deepseek-v4-flash  # 持正席

# ── 方舟 Coding Plan ────────────────────
# 支持模型：doubao-seed-2.0-pro, minimax-m3, glm-5.2 或 glm-latest,
#           deepseek-v4-flash, deepseek-v4-pro, kimi-k2.6
# WENYUAN_LLM_BASE_URL=https://ark.cn-beijing.volces.com/api/coding/v3
# WENYUAN_LLM_API_KEY=ark-xxxx
# WENYUAN_LLM_MODEL=deepseek-v4-flash

# 可用模型列表（前端下拉框展示，逗号分隔）
# 全局列表——未设置每席专用列表时使用此列表
# WENYUAN_AVAILABLE_MODELS=deepseek-v4-flash,deepseek-v4-pro
# 每席专用列表——同名模型用 value:标签 格式区分厂商
# WENYUAN_AVAILABLE_MODELS_MOUYUAN=deepseek-v4-flash,deepseek-v4-pro
# WENYUAN_AVAILABLE_MODELS_JINGSHI=doubao-seed-2.0-pro,minimax-m3,deepseek-v4-flash:deepseek-v4-flash（方舟Coding Plan）,deepseek-v4-pro:deepseek-v4-pro（方舟Coding Plan）,kimi-k2.6
# WENYUAN_AVAILABLE_MODELS_CHIZHENG=deepseek-v4-flash,deepseek-v4-pro

# Optional per-seat OpenAI-compatible overrides. Missing values fall back to the global settings.
WENYUAN_LLM_BASE_URL_MOUYUAN=
WENYUAN_LLM_API_KEY_MOUYUAN=
WENYUAN_LLM_MODEL_MOUYUAN=
WENYUAN_LLM_BASE_URL_JINGSHI=
WENYUAN_LLM_API_KEY_JINGSHI=
WENYUAN_LLM_MODEL_JINGSHI=
WENYUAN_LLM_BASE_URL_CHIZHENG=
WENYUAN_LLM_API_KEY_CHIZHENG=
WENYUAN_LLM_MODEL_CHIZHENG=

WENYUAN_DATABASE_URL=sqlite://wenyuan.db
WENYUAN_BIND=127.0.0.1:3210

# Search is used only when a session enables it. If unset, Wenyuan uses the
# free fallback pool: bing,duckduckgo,wikipedia. Set to none/off/disabled to
# disable backend search injection explicitly.
# WENYUAN_SEARCH_PROVIDER=bing,duckduckgo,wikipedia
# WENYUAN_SEARCH_PROVIDER=none
#
# Optional paid/self-hosted providers can be mixed into WENYUAN_SEARCH_PROVIDER:
# custom,doubao,tavily,google,searxng
# WENYUAN_SEARCH_API_URL=
# WENYUAN_SEARCH_API_KEY=
# WENYUAN_SEARCH_DOUBAO_KEY=
# WENYUAN_SEARCH_TAVILY_KEY=
# WENYUAN_SEARCH_GOOGLE_KEY=
# WENYUAN_SEARCH_GOOGLE_CX=
# WENYUAN_SEARCH_SEARXNG_URL=
#
# Code search is restricted to this root. Defaults to the server working
# directory when unset. The UI preferences file can also set this value.
# WENYUAN_CODE_SEARCH_ROOT=.
#
# Local user preferences are stored as JSON. Defaults to
# wenyuan-preferences.json in the server working directory.
# WENYUAN_PREFERENCES_PATH=wenyuan-preferences.json

# Mock scenarios:
# success_majority, timeout, single_seat_timeout, malformed_then_repair,
# always_malformed, single_seat_failure, split_then_convergence
WENYUAN_MOCK_SCENARIO=success_majority
